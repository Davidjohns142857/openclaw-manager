{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openclaw-manager/local-distillation.schema.json",
  "title": "LocalDistillationSnapshot",
  "type": "object",
  "required": [
    "contract_id",
    "generated_at",
    "source_session_count",
    "source_run_count",
    "scenario_count",
    "facts"
  ],
  "properties": {
    "contract_id": {
      "type": "string",
      "const": "local_distillation_v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_session_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_run_count": {
      "type": "integer",
      "minimum": 0
    },
    "scenario_count": {
      "type": "integer",
      "minimum": 0
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "fact_id",
          "scope_type",
          "scope_ref",
          "metric_name",
          "metric_value",
          "sample_size",
          "confidence",
          "metadata",
          "computed_at"
        ],
        "properties": {
          "fact_id": {
            "type": "string",
            "pattern": "^lfact_[A-Za-z0-9_-]+$"
          },
          "scope_type": {
            "type": "string",
            "enum": ["node", "scenario"]
          },
          "scope_ref": {
            "type": "string"
          },
          "metric_name": {
            "type": "string",
            "enum": [
              "closure_rate",
              "recovery_success_rate",
              "human_intervention_rate",
              "blocked_recurrence_rate",
              "run_trigger_rate"
            ]
          },
          "metric_value": {
            "type": "number",
            "minimum": 0
          },
          "sample_size": {
            "type": "integer",
            "minimum": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "metadata": {
            "type": "object"
          },
          "computed_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
