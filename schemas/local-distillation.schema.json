{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openclaw-manager/local-distillation.schema.json",
  "title": "LocalDistillationSnapshot",
  "type": "object",
  "required": [
    "contract_id",
    "generated_at",
    "source_session_count",
    "source_run_count",
    "scenario_count",
    "facts"
  ],
  "properties": {
    "contract_id": {
      "type": "string",
      "const": "local_distillation_v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_session_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_run_count": {
      "type": "integer",
      "minimum": 0
    },
    "scenario_count": {
      "type": "integer",
      "minimum": 0
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "fact_id",
          "fact_kind",
          "subject",
          "scenario_signature",
          "metric_name",
          "metric_value",
          "sample_size",
          "confidence",
          "aggregation_window",
          "privacy",
          "evidence_refs",
          "metadata",
          "computed_at"
        ],
        "properties": {
          "fact_id": {
            "type": "string",
            "pattern": "^fact_[A-Za-z0-9_-]+$"
          },
          "fact_kind": {
            "type": "string",
            "enum": ["raw_observation", "aggregate_metric"]
          },
          "subject": {
            "type": "object",
            "required": ["subject_type", "subject_ref", "subject_version"],
            "properties": {
              "subject_type": {
                "type": "string",
                "enum": ["node", "scenario", "session", "run", "skill", "workflow", "connector"]
              },
              "subject_ref": {
                "type": "string"
              },
              "subject_version": {
                "type": ["string", "null"]
              }
            },
            "additionalProperties": false
          },
          "scenario_signature": {
            "type": "string"
          },
          "metric_name": {
            "type": "string",
            "enum": [
              "closure_rate",
              "recovery_success_rate",
              "human_intervention_rate",
              "blocked_recurrence_rate",
              "run_trigger_rate"
            ]
          },
          "metric_value": {
            "type": "number",
            "minimum": 0
          },
          "sample_size": {
            "type": "integer",
            "minimum": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "aggregation_window": {
            "type": "object",
            "required": ["window_type", "start_at", "end_at"],
            "properties": {
              "window_type": {
                "type": "string",
                "enum": ["point_in_time", "closed_session_history"]
              },
              "start_at": {
                "type": ["string", "null"]
              },
              "end_at": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "privacy": {
            "type": "object",
            "required": [
              "privacy_tier",
              "export_policy",
              "contains_identifiers",
              "contains_content",
              "declaration"
            ],
            "properties": {
              "privacy_tier": {
                "type": "string",
                "enum": ["node_private", "aggregated_export_safe"]
              },
              "export_policy": {
                "type": "string",
                "enum": ["local_only", "public_submit_allowed"]
              },
              "contains_identifiers": {
                "type": "boolean"
              },
              "contains_content": {
                "type": "boolean"
              },
              "declaration": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object"
          },
          "computed_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
