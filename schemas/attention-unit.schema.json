{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openclaw-manager/attention-unit.schema.json",
  "title": "AttentionUnit",
  "type": "object",
  "required": [
    "attention_id",
    "session_id",
    "category",
    "urgency",
    "expected_human_action",
    "reasoning_summary",
    "confidence",
    "recommended_next_step",
    "created_at"
  ],
  "properties": {
    "attention_id": {
      "type": "string",
      "pattern": "^attn_[A-Za-z0-9_-]+$"
    },
    "session_id": {
      "type": "string",
      "pattern": "^sess_[A-Za-z0-9_-]+$"
    },
    "category": {
      "type": "string",
      "enum": ["waiting_human", "blocked", "stale", "desynced", "summary_drift"]
    },
    "urgency": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "expected_human_action": {
      "type": "string"
    },
    "reasoning_summary": {
      "type": "string"
    },
    "stale_after": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recommended_next_step": {
      "type": "string"
    },
    "attention_priority": {
      "type": "number"
    },
    "metadata": {
      "type": "object"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}

